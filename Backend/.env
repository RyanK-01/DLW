# Firebase Configuration
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json
# OR use GOOGLE_APPLICATION_CREDENTIALS environment variable

# Twilio SMS (for public safety advisories)
TWILIO_ACCOUNT_SID= insert_account_sid_here
TWILIO_AUTH_TOKEN= insert_auth_token_here
TWILIO_PHONE_NUMBER= insert_twilio_phone_number_here
TEST_USER_PHONE = insert_test_user_phone_number_here

# Configuration
OFFICER_NOTIFICATION_RADIUS_KM=2.0
TOP_N_OFFICERS_TO_NOTIFY=5
CIVILIAN_ADVISORY_RADIUS_KM=1.0

# CORS (restrict in production)
ALLOWED_ORIGINS=https://your-frontend.vercel.app

# Edge Worker -> Backend
EDGE_BACKEND_URL=http://127.0.0.1:8000

# YOLOv8 (person detection)
YOLO_WEIGHTS=yolov8n.pt
YOLO_CONF_THRESHOLD=0.25
YOLO_DEVICE=cpu

# MobileNetV2 violence model (trained on violent video dataset)
MOBILENET_MODEL_PATH=Backend/ViolenceDetectionModel.h5
MOBILENET_BACKEND=auto
MOBILENET_INPUT_SIZE=64
MOBILENET_VIOLENCE_CLASS_INDEX=1
MOBILENET_PREPROCESS_MODE=zero_one
MAX_CLIP_FRAMES_FOR_ACTION=16
SEQUENCE_LENGTH=16

# Fight gating + temporal smoothing
TARGET_FPS=12
MIN_PEOPLE_FOR_ACTION=2
PROXIMITY_DISTANCE_PX_THRESHOLD=80
OVERLAP_RATIO_THRESHOLD=0.1
MOTION_SCORE_THRESHOLD=0.25
BUFFER_SECONDS=12
ACTION_WINDOW_SECONDS=4
INFERENCE_INTERVAL_SECONDS=1
FIGHT_THRESHOLD_T=0.6
SMOOTHING_ALPHA=0.6
COOLDOWN_SECONDS=30
KEYFRAME_COUNT=3
INCIDENT_CLIP_SECONDS=10
ARTIFACTS_ROOT=./artifacts
HEARTBEAT_INTERVAL_SECONDS=5

# Armed threat detection (YOLOv8 weapon model)
WEAPON_WEIGHTS=best.pt
WEAPON_CONF_THRESHOLD=0.5
WEAPON_TARGET_FPS=7
WEAPON_PERSIST_N=3
WEAPON_WINDOW_M=5
ARMED_MIN_PEOPLE_CONTEXT=2
ARMED_COOLDOWN_SECONDS=45
